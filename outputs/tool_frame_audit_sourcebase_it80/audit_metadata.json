{
  "audit": "tool_frame_audit_sourcebase_it80",
  "inputs": {
    "position_baseline": "outputs/sourcebase_true_proxy_all_it80/baseline_results.csv",
    "pose_baseline": "outputs/sourcebase_true_pose_it80/baseline_results.csv",
    "ur5e_tcp_position": "outputs/ur5e_robotiq2f85_tcp_proxy_sourcebase_it80/position/baseline_results.csv",
    "ur5e_tcp_pose": "outputs/ur5e_robotiq2f85_tcp_proxy_sourcebase_it80/pose/baseline_results.csv",
    "ur5e_source_mjcf": "data/armforge/models/mujoco_menagerie/universal_robots_ur5e/ur5e.xml",
    "xarm6_generated_mjcf": "outputs/generated_models/xarm6_true/xarm6_true.xml",
    "ur5e_tcp_generated_mjcf": "outputs/generated_models/ur5e_robotiq2f85_tcp_proxy/ur5e_true_robotiq2f85_tcp_proxy.xml"
  },
  "normalization": {
    "target_quat_wxyz": "Unit-normalized for audit display; FK internally normalizes quaternions when converting them to rotation matrices."
  },
  "run_settings": {
    "base_pose_mode": "source",
    "max_waypoints_per_trajectory": 80,
    "max_iters": 80,
    "position_tolerance_m": 0.002,
    "pose_orientation_tolerance_rad": 0.1,
    "pose_orientation_format": "rotvec"
  },
  "outputs": {
    "tool_frame_audit_csv": "outputs/tool_frame_audit_sourcebase_it80/tool_frame_audit.csv",
    "comparison_groups_csv": "outputs/tool_frame_audit_sourcebase_it80/comparison_groups.csv",
    "analysis_report": "outputs/tool_frame_audit_sourcebase_it80/analysis_report.md"
  }
}
